         05 WARN-03.
            10 COL-CODE PIC X(12) VALUE "RCL-W03".
            10 COL-CAT  PIC X(20) VALUE "missing-required".
            10 COL-DESC PIC X(80) VALUE "AUTHOR or DATE-WRITTEN absent from IDENTIFICATION DIVISION.".
         05 WARN-04.
            10 COL-CODE PIC X(12) VALUE "RCL-W04".
            10 COL-CAT  PIC X(20) VALUE "structural".
            10 COL-DESC PIC X(80) VALUE "Procedure section defined but contains no DISPLAY statements.".
         05 WARN-05.
            10 COL-CODE PIC X(12) VALUE "RCL-W05".
            10 COL-CAT  PIC X(20) VALUE "type-mismatch".
            10 COL-DESC PIC X(80) VALUE "Numeric PIC 9 field used in a string-accepting element — implicit coercion.".

      * ── Sidebar navigation ─────────────────────────────────
      01 DOCS-NAV.
         05 NAV-SECTION-1.
            10 GROUP-LABEL     PIC X(30) VALUE "OVERVIEW".
            10 NAV-LINK-1      PIC X(30) VALUE "Introduction".
            10 NAV-LINK-1-HREF PIC X(80) VALUE "#intro".
            10 NAV-LINK-2      PIC X(30) VALUE "Quick Start".
            10 NAV-LINK-2-HREF PIC X(80) VALUE "#quickstart".
         05 NAV-SECTION-2.
            10 GROUP-LABEL     PIC X(30) VALUE "LANGUAGE".
            10 NAV-LINK-1      PIC X(30) VALUE "Divisions".
            10 NAV-LINK-1-HREF PIC X(80) VALUE "#divisions".
            10 NAV-LINK-2      PIC X(30) VALUE "PIC Types".
            10 NAV-LINK-2-HREF PIC X(80) VALUE "#pic-types".
            10 NAV-LINK-3      PIC X(30) VALUE "Elements".
            10 NAV-LINK-3-HREF PIC X(80) VALUE "#elements".
            10 NAV-LINK-4      PIC X(30) VALUE "Copybooks".
            10 NAV-LINK-4-HREF PIC X(80) VALUE "#copybooks".
            10 NAV-LINK-5      PIC X(30) VALUE "Components".
            10 NAV-LINK-5-HREF PIC X(80) VALUE "#components".
            10 NAV-LINK-6      PIC X(30) VALUE "Value Language".
            10 NAV-LINK-6-HREF PIC X(80) VALUE "#value-language".
            10 NAV-LINK-7      PIC X(30) VALUE "Data Loading".
            10 NAV-LINK-7-HREF PIC X(80) VALUE "#load-from".
         05 NAV-SECTION-3.
            10 GROUP-LABEL     PIC X(30) VALUE "DIAGNOSTICS".
            10 NAV-LINK-1      PIC X(30) VALUE "Error Codes".
            10 NAV-LINK-1-HREF PIC X(80) VALUE "#error-codes".
            10 NAV-LINK-2      PIC X(30) VALUE "Strict Mode".
            10 NAV-LINK-2-HREF PIC X(80) VALUE "#strict-mode".
         05 NAV-SECTION-4.
            10 GROUP-LABEL     PIC X(30) VALUE "CLI".
            10 NAV-LINK-1      PIC X(30) VALUE "Commands".
            10 NAV-LINK-1-HREF PIC X(80) VALUE "#cli".
         05 NAV-SECTION-5.
            10 GROUP-LABEL     PIC X(30) VALUE "ECOSYSTEM".
            10 NAV-LINK-1      PIC X(30) VALUE "Component Library".
            10 NAV-LINK-1-HREF PIC X(80) VALUE "#component-library".
         05 NAV-SECTION-6.
            10 GROUP-LABEL     PIC X(30) VALUE "PROJECT".
            10 NAV-LINK-1      PIC X(30) VALUE "GitHub".
            10 NAV-LINK-1-HREF PIC X(80) VALUE "https://github.com/semanticintent/recall-compiler".
            10 NAV-LINK-2      PIC X(30) VALUE "npm".
            10 NAV-LINK-2-HREF PIC X(80) VALUE "https://www.npmjs.com/package/@semanticintent/recall-compiler".

PROCEDURE DIVISION.

   RENDER-NAV.
      COPY FROM "components/nav.rcpy".

   RENDER-LAYOUT.
      DISPLAY SECTION ID "docs-layout"
         WITH LAYOUT SIDEBAR
         WITH PADDING NONE.

         DISPLAY SIDEBAR-NAV USING DOCS-NAV
            WITH LOGO "RECALL DOCS"
            WITH STICKY YES.

         * ── Introduction ─────────────────────────────────────
         DISPLAY SECTION ID "intro"
            WITH LAYOUT STACK
            WITH PADDING LARGE.
            DISPLAY LABEL "OVERVIEW".
            DISPLAY HEADING-1 "Introduction"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH INTRO-BODY.
            DISPLAY CALLOUT "RECALL is not a framework, runtime, or templating engine. It is a compiler. Source in. HTML out."
               WITH TYPE NOTE.
         STOP SECTION.

         * ── Quick Start ──────────────────────────────────────
         DISPLAY SECTION ID "quickstart"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "OVERVIEW".
            DISPLAY HEADING-2 "Quick Start"
               WITH STYLE MONO.
            DISPLAY CODE-BLOCK INSTALL-CMD
               WITH LANGUAGE "bash".
            DISPLAY CODE-BLOCK MINIMAL-EX
               WITH LANGUAGE "RECALL".
            DISPLAY CALLOUT "No config file. No build pipeline. Open the .html output directly in any browser."
               WITH TYPE TIP.
         STOP SECTION.

         * ── Divisions ────────────────────────────────────────
         DISPLAY SECTION ID "divisions"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "LANGUAGE".
            DISPLAY HEADING-2 "Divisions"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH DIVISIONS-BODY.
            DISPLAY TABLE USING DIVISION-REF
               WITH COLUMNS "DIVISION, REQUIRED, DESCRIPTION".
            DISPLAY CALLOUT "Divisions must appear in order: IDENTIFICATION, ENVIRONMENT, DATA, COMPONENT, PROCEDURE. Omitting COMPONENT DIVISION is valid. Omitting any other aborts compilation."
               WITH TYPE WARNING.
         STOP SECTION.

         * ── PIC Types ────────────────────────────────────────
         DISPLAY SECTION ID "pic-types"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "LANGUAGE".
            DISPLAY HEADING-2 "PIC Types"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH PIC-BODY.
            DISPLAY TABLE USING PIC-TYPE-REF
               WITH COLUMNS "DECLARATION, KIND, USAGE".
            DISPLAY CODE-BLOCK PIC-EX
               WITH LANGUAGE "RECALL".
            DISPLAY CALLOUT "Run `recall schema --json` to see the live element type contracts — which PIC types each element accepts."
               WITH TYPE TIP.
         STOP SECTION.

         * ── Elements ─────────────────────────────────────────
         DISPLAY SECTION ID "elements"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "LANGUAGE".
            DISPLAY HEADING-2 "Elements"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH ELEMENTS-BODY.
            DISPLAY TABLE USING ELEMENT-REF
               WITH COLUMNS "ELEMENT, ARGUMENTS, DESCRIPTION".
            DISPLAY CALLOUT "SECTION elements close with STOP SECTION. All other elements are single-line DISPLAY statements."
               WITH TYPE NOTE.
         STOP SECTION.

         * ── Copybooks ────────────────────────────────────────
         DISPLAY SECTION ID "copybooks"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "LANGUAGE".
            DISPLAY HEADING-2 "Copybooks"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH COPY-BODY.
            DISPLAY CODE-BLOCK "COPY FROM components/nav.rcpy."
               WITH LANGUAGE "RECALL".
            DISPLAY CALLOUT "A copybook can contain any RECALL division content. COPY FROM is resolved at compile time — the result is one self-contained HTML file."
               WITH TYPE NOTE.
            DISPLAY CALLOUT "Use `recall check --inspect` to see what DATA symbols are generated after all COPY FROM and LOAD FROM statements are resolved."
               WITH TYPE TIP.
         STOP SECTION.

         * ── Components ───────────────────────────────────────
         DISPLAY SECTION ID "components"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "LANGUAGE".
            DISPLAY HEADING-2 "Components"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH COMPONENTS-BODY.
            DISPLAY HEADING-3 "Defining a component".
            DISPLAY CODE-BLOCK COMPONENT-DEF-EX
               WITH LANGUAGE "RECALL".
            DISPLAY HEADING-3 "Invoking with WITH DATA".
            DISPLAY CODE-BLOCK COMPONENT-USE-EX
               WITH LANGUAGE "RECALL".
            DISPLAY HEADING-3 "REQUIRED parameters".
            DISPLAY CODE-BLOCK REQUIRED-EX
               WITH LANGUAGE "RECALL".
            DISPLAY CALLOUT "REQUIRED on an ACCEPTS parameter makes it a compile-time contract. Calling the component without that parameter fires RCL-017 — no output is written."
               WITH TYPE WARNING.
            DISPLAY HEADING-3 "COMMENT clause".
            DISPLAY CODE-BLOCK COMMENT-EX
               WITH LANGUAGE "RECALL".
            DISPLAY CALLOUT "COMMENT clauses surface in `recall check --inspect` output and `--format json` under fieldIntent. They have no effect on compiled HTML — intent only."
               WITH TYPE NOTE.
         STOP SECTION.

         * ── Value Language ───────────────────────────────────
         DISPLAY SECTION ID "value-language"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "LANGUAGE".
            DISPLAY HEADING-2 "Value Language"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH VALUE-LANG-BODY.
            DISPLAY HEADING-3 "VALUE BLOCK — multi-line strings".
            DISPLAY CODE-BLOCK VALUE-BLOCK-EX
               WITH LANGUAGE "RECALL".
            DISPLAY CALLOUT "PIC X declared without a size (PIC X VALUE BLOCK.) is auto-sized by the compiler to fit the block content exactly."
               WITH TYPE NOTE.
            DISPLAY HEADING-3 "RECORD types — reusable group shapes".
            DISPLAY CODE-BLOCK RECORD-EX
               WITH LANGUAGE "RECALL".
            DISPLAY CALLOUT "RECORD types are expanded at compile time. Use LIKE to stamp a defined shape onto a group field. All field names are generated deterministically."
               WITH TYPE NOTE.
         STOP SECTION.

         * ── Data Loading ─────────────────────────────────────
         DISPLAY SECTION ID "load-from"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "LANGUAGE".
            DISPLAY HEADING-2 "Data Loading"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH LOAD-BODY.
            DISPLAY HEADING-3 "Load from JSON".
            DISPLAY CODE-BLOCK LOAD-JSON-EX
               WITH LANGUAGE "RECALL".
            DISPLAY HEADING-3 "Load from CSV".
            DISPLAY CODE-BLOCK LOAD-CSV-EX
               WITH LANGUAGE "RECALL".
            DISPLAY CALLOUT "LOAD FROM runs at compile time. No data files are bundled into the HTML — only the resolved field values are embedded."
               WITH TYPE NOTE.
            DISPLAY CALLOUT "Multiple LOAD FROM statements in one DATA DIVISION are supported. Data from all files is merged into a single symbol table."
               WITH TYPE TIP.
         STOP SECTION.

         * ── Error Codes ──────────────────────────────────────
         DISPLAY SECTION ID "error-codes"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "DIAGNOSTICS".
            DISPLAY HEADING-2 "Error Codes"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH DIAG-BODY.
            DISPLAY CALLOUT "Every diagnostic has a stable code. RCL-001 means the same thing forever. Use `recall explain RCL-001` for the full reference on any code."
               WITH TYPE NOTE.
            DISPLAY HEADING-3 "Errors — abort compilation, no output written".
            DISPLAY TABLE USING ERROR-REF
               WITH COLUMNS "CODE, CATEGORY, DESCRIPTION".
            DISPLAY HEADING-3 "Warnings — shown but compilation continues".
            DISPLAY TABLE USING WARN-REF
               WITH COLUMNS "CODE, CATEGORY, DESCRIPTION".
            DISPLAY CALLOUT "All 26 codes are actively enforced. Silent failures are errors. If a program compiles, it is valid."
               WITH TYPE TIP.
         STOP SECTION.

         * ── Strict Mode ──────────────────────────────────────
         DISPLAY SECTION ID "strict-mode"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "DIAGNOSTICS".
            DISPLAY HEADING-2 "Strict Mode"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH STRICT-BODY.
            DISPLAY HEADING-3 "Terminal output".
            DISPLAY CODE-BLOCK DIAGNOSTIC-EX
               WITH LANGUAGE "bash".
            DISPLAY HEADING-3 "JSON output".
            DISPLAY CODE-BLOCK JSON-EX
               WITH LANGUAGE "json".
            DISPLAY HEADING-3 "Exit codes".
            DISPLAY CODE-BLOCK EXIT-CODES-EX
               WITH LANGUAGE "bash".
            DISPLAY CALLOUT "Use `--quiet` in CI for exit-code-only validation with no terminal output. Use `--strict` to promote all warnings to errors."
               WITH TYPE TIP.
         STOP SECTION.

         * ── CLI Reference ────────────────────────────────────
         DISPLAY SECTION ID "cli"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "CLI".
            DISPLAY HEADING-2 "Command Reference"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH CLI-BODY.

            DISPLAY HEADING-3 "recall compile — single file".
            DISPLAY CODE-BLOCK COMPILE-EX
               WITH LANGUAGE "bash".

            DISPLAY HEADING-3 "recall build — directory".
            DISPLAY CODE-BLOCK BUILD-EX
               WITH LANGUAGE "bash".

            DISPLAY HEADING-3 "recall check — validate without compiling".
            DISPLAY CODE-BLOCK CHECK-EX
               WITH LANGUAGE "bash".
            DISPLAY CALLOUT "recall check is the primary quality gate. --strict for CI. --format json for editor integrations. --inspect to see LOAD FROM symbols before type-checking."
               WITH TYPE NOTE.

            DISPLAY HEADING-3 "recall fix — auto-apply safe fixes".
            DISPLAY CODE-BLOCK FIX-EX
               WITH LANGUAGE "bash".
            DISPLAY CALLOUT "Safe fixes include: PIC resize when VALUE exceeds declared length (RCL-002), AUTHOR insertion (RCL-W03), and empty section removal (RCL-W04)."
               WITH TYPE TIP.

            DISPLAY HEADING-3 "recall history — git-aware DATA field diff".
            DISPLAY CODE-BLOCK HISTORY-EX
               WITH LANGUAGE "bash".

            DISPLAY HEADING-3 "recall stats — orientation snapshot".
            DISPLAY CODE-BLOCK STATS-EX
               WITH LANGUAGE "bash".

            DISPLAY HEADING-3 "recall schema — live element registry".
            DISPLAY CODE-BLOCK SCHEMA-EX
               WITH LANGUAGE "bash".
            DISPLAY CALLOUT "recall schema queries the installed compiler directly. The output reflects the actual compiler state — drift between docs and implementation is structurally impossible."
               WITH TYPE NOTE.

            DISPLAY HEADING-3 "recall explain — per-code reference".
            DISPLAY CODE-BLOCK EXPLAIN-EX
               WITH LANGUAGE "bash".
         STOP SECTION.

         * ── Component Library ────────────────────────────────
         DISPLAY SECTION ID "component-library"
            WITH LAYOUT STACK
            WITH PADDING MEDIUM.
            DISPLAY LABEL "ECOSYSTEM".
            DISPLAY HEADING-2 "Component Library"
               WITH STYLE MONO.
            DISPLAY PARAGRAPH LIB-BODY.
            DISPLAY CODE-BLOCK LIB-INSTALL-EX
               WITH LANGUAGE "bash".
            DISPLAY CODE-BLOCK LIB-USAGE-EX
               WITH LANGUAGE "RECALL".
            DISPLAY CALLOUT "recall-ui components declare strict ACCEPTS contracts. Your DATA DIVISION field names must match exactly. Run `recall check` after adding components."
               WITH TYPE WARNING.
            DISPLAY CALLOUT "Themes (dark.rcpy) go in ENVIRONMENT DIVISION via COPY FROM. Components go in COMPONENT DIVISION. The separation is enforced by the compiler."
               WITH TYPE NOTE.
         STOP SECTION.

      STOP SECTION.

   RENDER-FOOTER.
      COPY FROM "components/footer.rcpy".

   STOP RUN.
